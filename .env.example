# Required
ANTHROPIC_API_KEY=sk-ant-...
ODDS_API_KEY=...          # theoddsapi.com -- free tier 500 req/month; the season cron plan needs the 20K tier
DATABASE_URL=postgresql+psycopg://fairline:fairline@localhost:5432/fairline

# Optional
LANGCHAIN_API_KEY=lsv2_pt_...  # LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=fairline
STRIPE_SECRET_KEY=sk_test_...  # Stripe test mode
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...      # $29/mo Pro plan price ID

# Application
CLAUDE_MODEL=claude-sonnet-4-6
SITE_URL=http://localhost:8000
FAIRLINE_ENV=               # set to "production" to refuse boot without DATABASE_URL
FAIRLINE_SIM_WEIGHT=0.25    # sim share of the blend; raise only on sim-report evidence
FAIRLINE_WEBHOOK_URL=       # Slack/Discord-compatible URL for steam alerts from `fairline watch`
